{
  "id": null,
  "title": "JobSeeker Analytics",
  "uid": "jobseeker-dash-v6",
  "tags": [
    "jobseeker"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 6,
  "refresh": "10s",
  "panels": [
    {
      "id": 101,
      "title": "API Request Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "sum(rate(http_requests_total[5m]))",
          "refId": "A",
          "format": "time_series",
          "instant": false,
          "legendFormat": ""
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        }
      }
    },
    {
      "id": 102,
      "title": "API Error Rate (4xx & 5xx)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "sum(rate(http_requests_total{status=~\"[45]..\"}[5m]))",
          "refId": "A",
          "format": "time_series",
          "instant": false,
          "legendFormat": ""
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        }
      }
    },
    {
      "id": 103,
      "title": "API P95 Latency",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "refId": "A",
          "format": "time_series",
          "instant": false,
          "legendFormat": ""
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        }
      }
    },
    {
      "id": 104,
      "title": "API Errors Table (Last 24h)",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "sum by (handler, status) (increase(http_requests_total{status=~\"[45]..\"}[24h])) > 0",
          "refId": "A",
          "format": "table",
          "instant": false,
          "legendFormat": ""
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 201,
      "title": "Scraper Run Status (1=Pass, 0=Fail)",
